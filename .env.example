# Variáveis de ambiente para o Portal Pred.IO
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env com valores reais

# URL do webhook n8n para o Assistente Técnico
N8N_ASSISTANT_WEBHOOK_URL=

# Credenciais Google Sheets (base64 do JSON da conta de serviço)
GCP_CREDENTIALS_B64=

# Alternativas de credenciais (apenas uma é necessária)
# GCP_CREDENTIALS_JSON=
# REPORTS_STORAGE_PROVIDER=sheets
# REPORTS_BASE_PATH=
